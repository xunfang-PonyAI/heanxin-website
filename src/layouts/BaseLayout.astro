---
import "../styles/global.css";
// Self-hosted Latin fonts — no external Google Fonts request (reliable in China).
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/600.css";
import "@fontsource/outfit/700.css";
import "@fontsource/outfit/800.css";
import "@fontsource/work-sans/400.css";
import "@fontsource/work-sans/500.css";
import "@fontsource/work-sans/600.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, url } from "../lib/i18n";
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath } = Astro.props;
const { company, contact } = site;

const fullTitle = `${title} | ${company.shortName.zh} Heanxin`;
const canonical = new URL(
  canonicalPath ? url(canonicalPath) : Astro.url.pathname,
  Astro.site
).toString();
const ogImage = new URL(url("og-image.svg"), Astro.site).toString();
const homeUrl = new URL(url("/"), Astro.site).toString();
const serviceOffers = [
  "Plastic Injection Molding",
  "Mold Development",
  "Insert Molding",
  "Hardware-Plastic Combined Parts",
  "OEM / ODM Manufacturing",
  "Assembly and Finishing",
];

// Structured data helps OEM/ODM buyers find the company via search engines.
const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${homeUrl}#organization`,
    name: company.name.en,
    alternateName: company.name.zh,
    url: homeUrl,
    logo: ogImage,
    email: contact.email,
    telephone: contact.phone,
    description: description,
    address: {
      "@type": "PostalAddress",
      streetAddress: "Room 101, No. 606 Miaobianwang Road, Shipai Town",
      addressLocality: "Dongguan",
      addressRegion: "Guangdong",
      addressCountry: "CN",
    },
    contactPoint: {
      "@type": "ContactPoint",
      contactType: "sales",
      telephone: contact.phone,
      email: contact.email,
      areaServed: "Worldwide",
      availableLanguage: ["zh-CN", "en"],
    },
    makesOffer: serviceOffers,
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Plastic injection molding and OEM / ODM services",
      itemListElement: serviceOffers.map((offer) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: offer,
        },
      })),
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: `${company.shortName.en} Website`,
    alternateName: company.name.zh,
    url: homeUrl,
    inLanguage: ["zh-CN", "en"],
    publisher: {
      "@id": `${homeUrl}#organization`,
    },
  },
];
---

<!doctype html>
<html lang="zh" data-lang="zh">
  <head>
    <script is:inline>
      // Keep the active language stable across view transitions.
      // First-time visitors: Chinese if the browser prefers Chinese, otherwise
      // English. The choice persists in localStorage and is copied into the
      // incoming document before Astro swaps pages, so it does not snap back
      // to the server default during client navigation.
      (function () {
        function getPreferredLang() {
          try {
            var stored = localStorage.getItem("lang");
            if (stored === "en" || stored === "zh") return stored;
            var nav = (navigator.language || "").toLowerCase();
            return nav.indexOf("zh") === 0 ? "zh" : "en";
          } catch (e) {
            return "zh";
          }
        }

        function applyLang(root, lang) {
          root.setAttribute("data-lang", lang);
          root.setAttribute("lang", lang);
        }

        var el = document.documentElement;
        var lang = getPreferredLang();
        applyLang(el, lang);

        document.addEventListener("astro:before-swap", function (event) {
          applyLang(event.newDocument.documentElement, getPreferredLang());
        });

        // Enable reveal-on-scroll only when JS runs (content stays visible for
        // no-JS visitors and crawlers — SEO safe).
        el.classList.add("js-reveal");
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url("favicon.svg")} />
    <link rel="canonical" href={canonical} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={company.name.en} />
    <meta property="og:locale" content="zh_CN" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Smooth cross-page transitions (progressive enhancement; static HTML
         is unchanged, browsers without support fall back to normal navigation). -->
    <ClientRouter />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a
      href="#main"
      class="focus:bg-brand-600 sr-only focus:not-sr-only focus:absolute focus:z-50 focus:rounded-md focus:px-4 focus:py-2 focus:text-white"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Toggle between Chinese and English; persist the choice.
      // Bound once on the persistent document (survives view transitions).
      if (!window.__heanxinLangBound) {
        window.__heanxinLangBound = true;
        document.addEventListener("click", function (e) {
          var btn = e.target.closest("[data-lang-toggle]");
          if (!btn) return;
          var el = document.documentElement;
          var next = el.getAttribute("data-lang") === "en" ? "zh" : "en";
          el.setAttribute("data-lang", next);
          el.setAttribute("lang", next);
          try {
            localStorage.setItem("lang", next);
          } catch (e) {}
        });
      }
    </script>
    <script is:inline>
      // Reveal-on-scroll enhancement. Content is already visible; this only
      // animates it in. Honors reduced-motion and degrades gracefully.
      // Runs on first load AND after every view-transition navigation so cards
      // on newly loaded pages are revealed (otherwise they'd stay hidden).
      (function () {
        function initReveal() {
          var els = document.querySelectorAll("[data-reveal]:not(.is-visible)");
          if (!els.length) return;
          var reduce =
            window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
          if (reduce || !("IntersectionObserver" in window)) {
            for (var i = 0; i < els.length; i++) els[i].classList.add("is-visible");
            return;
          }
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;
                var el = entry.target;
                // Stagger siblings sharing a parent for a refined cascade.
                var sibs = Array.prototype.filter.call(el.parentElement.children, function (c) {
                  return c.hasAttribute("data-reveal");
                });
                el.style.transitionDelay = Math.min(sibs.indexOf(el), 6) * 70 + "ms";
                el.classList.add("is-visible");
                io.unobserve(el);
              });
            },
            { rootMargin: "0px 0px -10% 0px", threshold: 0.08 }
          );
          for (var j = 0; j < els.length; j++) io.observe(els[j]);
        }
        document.addEventListener("astro:page-load", initReveal);
      })();
    </script>
    <script is:inline>
      // Product carousel: auto-advance every 5s, infinite loop, prev/next + dots,
      // swipe, keyboard (←/→), pause on hover/focus/tab-hidden. Re-inits after
      // each view transition. Honors reduced-motion (no autoplay).
      (function () {
        function initCarousels() {
          var roots = document.querySelectorAll("[data-carousel]:not([data-carousel-ready])");
          Array.prototype.forEach.call(roots, function (root) {
            var track = root.querySelector("[data-carousel-track]");
            var slides = Array.prototype.slice.call(root.querySelectorAll("[data-carousel-slide]"));
            var dots = Array.prototype.slice.call(root.querySelectorAll("[data-carousel-dot]"));
            var status = root.querySelector("[data-carousel-status]");
            var prevBtn = root.querySelector("[data-carousel-prev]");
            var nextBtn = root.querySelector("[data-carousel-next]");
            var n = slides.length;
            if (!track || !n) return;
            root.setAttribute("data-carousel-ready", "");
            var index = 0;
            var timer = null;
            var reduce =
              window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

            function update() {
              for (var i = 0; i < dots.length; i++) {
                var active = i === index;
                dots[i].classList.toggle("is-active", active);
                dots[i].setAttribute("aria-current", active ? "true" : "false");
              }
              for (var s = 0; s < slides.length; s++) {
                slides[s].setAttribute("aria-hidden", s === index ? "false" : "true");
              }
              if (status) status.textContent = index + 1 + " / " + n;
            }
            function go(i) {
              index = ((i % n) + n) % n;
              track.scrollTo({
                left: index * track.clientWidth,
                behavior: reduce ? "auto" : "smooth",
              });
              update();
            }
            function start() {
              if (reduce || timer) return;
              timer = setInterval(function () {
                go(index + 1);
              }, 5000);
            }
            function stop() {
              if (timer) {
                clearInterval(timer);
                timer = null;
              }
            }
            function nav(i) {
              go(i);
              stop();
              start();
            }

            if (nextBtn)
              nextBtn.addEventListener("click", function () {
                nav(index + 1);
              });
            if (prevBtn)
              prevBtn.addEventListener("click", function () {
                nav(index - 1);
              });
            for (var d = 0; d < dots.length; d++) {
              (function (di) {
                dots[di].addEventListener("click", function () {
                  nav(di);
                });
              })(d);
            }

            root.addEventListener("mouseenter", stop);
            root.addEventListener("mouseleave", start);
            root.addEventListener("focusin", stop);
            root.addEventListener("focusout", start);
            root.addEventListener("keydown", function (e) {
              if (e.key === "ArrowLeft") nav(index - 1);
              else if (e.key === "ArrowRight") nav(index + 1);
            });

            // Keep index in sync when the user swipes/scrolls the track.
            var st;
            track.addEventListener("scroll", function () {
              clearTimeout(st);
              st = setTimeout(function () {
                var i = Math.round(track.scrollLeft / track.clientWidth);
                if (i !== index) {
                  index = Math.max(0, Math.min(n - 1, i));
                  update();
                }
              }, 120);
            });
            window.addEventListener("resize", function () {
              track.scrollTo({ left: index * track.clientWidth, behavior: "auto" });
            });
            document.addEventListener("visibilitychange", function () {
              if (document.hidden) stop();
              else start();
            });

            update();
            start();
          });
        }
        document.addEventListener("astro:page-load", initCarousels);
      })();
    </script>
  </body>
</html>
