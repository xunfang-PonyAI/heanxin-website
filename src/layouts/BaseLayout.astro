---
import "../styles/global.css";
// Self-hosted Latin fonts — no external Google Fonts request (reliable in China).
import "@fontsource/outfit/400.css";
import "@fontsource/outfit/500.css";
import "@fontsource/outfit/600.css";
import "@fontsource/outfit/700.css";
import "@fontsource/outfit/800.css";
import "@fontsource/work-sans/400.css";
import "@fontsource/work-sans/500.css";
import "@fontsource/work-sans/600.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site, url } from "../lib/i18n";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const { company, contact } = site;

const fullTitle = `${title} | ${company.shortName.zh} Heanxin`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL(url("og-image.svg"), Astro.site).toString();
const homeUrl = new URL(url("/"), Astro.site).toString();

// Structured data helps OEM/ODM buyers find the company via search engines.
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: company.name.en,
  alternateName: company.name.zh,
  url: homeUrl,
  logo: ogImage,
  email: contact.email,
  telephone: contact.phone,
  description: description,
  address: {
    "@type": "PostalAddress",
    streetAddress: "Room 101, No. 606 Miaobianwang Road, Shipai Town",
    addressLocality: "Dongguan",
    addressRegion: "Guangdong",
    addressCountry: "CN",
  },
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "sales",
    telephone: contact.phone,
    email: contact.email,
    areaServed: "Worldwide",
    availableLanguage: ["zh-CN", "en"],
  },
  makesOffer: [
    "Plastic Injection Molding",
    "Mold Development",
    "Insert Molding",
    "Hardware-Plastic Combined Parts",
    "OEM / ODM Manufacturing",
  ],
};
---

<!doctype html>
<html lang="zh" data-lang="zh">
  <head>
    <script is:inline>
      // Set the display language before paint (no FOUC). First-time visitors:
      // Chinese if the browser prefers Chinese, otherwise English. Choice persists.
      (function () {
        try {
          var stored = localStorage.getItem("lang");
          var nav = (navigator.language || "").toLowerCase();
          var lang = stored || (nav.indexOf("zh") === 0 ? "zh" : "en");
          var el = document.documentElement;
          el.setAttribute("data-lang", lang);
          el.setAttribute("lang", lang);
        } catch (e) {}
      })();
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={url("favicon.svg")} />
    <link rel="canonical" href={canonical} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content={company.name.en} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a
      href="#main"
      class="focus:bg-brand-600 sr-only focus:not-sr-only focus:absolute focus:z-50 focus:rounded-md focus:px-4 focus:py-2 focus:text-white"
      >Skip to content</a
    >
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      // Toggle between Chinese and English; persist the choice.
      document.addEventListener("click", function (e) {
        var btn = e.target.closest("[data-lang-toggle]");
        if (!btn) return;
        var el = document.documentElement;
        var next = el.getAttribute("data-lang") === "en" ? "zh" : "en";
        el.setAttribute("data-lang", next);
        el.setAttribute("lang", next);
        try {
          localStorage.setItem("lang", next);
        } catch (e) {}
      });
    </script>
  </body>
</html>
