---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionHeader from "../components/SectionHeader.astro";
import PhotoPlaceholder from "../components/PhotoPlaceholder.astro";
import T from "../components/T.astro";
import industries from "../content/industries.json";
---

<BaseLayout
  title="应用领域"
  description="禾安鑫的定制塑胶与五金塑胶组合件广泛应用于电子设备、工业控制、智能家居、小型家电、汽车电子及医疗健康设备等行业。"
>
  <section class="container-page pt-12 pb-8">
    <SectionHeader
      eyebrow={industries.header.eyebrow}
      title={industries.header.title}
      subtitle={industries.header.subtitle}
      as="h1"
    />
  </section>

  <section class="container-page pb-12">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        industries.industries.map((item) => (
          <article data-reveal class="card-base card-interactive overflow-hidden">
            <PhotoPlaceholder
              alt={item.alt ?? item.title}
              ratio="video"
              labelStyle="none"
              class="rounded-none border-0"
            />
            <div class="p-5">
              <h2 class="font-display text-brand-700 text-xl font-semibold">
                <T text={item.title} />
              </h2>
              <p class="text-muted mt-3 text-[15px] leading-relaxed">
                <T text={item.desc} />
              </p>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
