---
import BaseLayout from "../layouts/BaseLayout.astro";
import { url } from "../lib/i18n";
---

<BaseLayout title="页面未找到 404" description="抱歉，您访问的页面不存在。">
  <section
    class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center"
  >
    <p class="font-display text-brand-200 text-7xl font-bold">404</p>
    <h1 class="font-display text-brand-700 mt-4 text-2xl font-semibold">
      页面未找到 · Page Not Found
    </h1>
    <p class="text-muted mt-3 max-w-md">
      抱歉，您访问的页面不存在或已被移动。
      <span class="mt-1 block text-sm">Sorry, the page you are looking for could not be found.</span
      >
    </p>
    <a
      href={url("/")}
      class="bg-brand-500 hover:bg-brand-600 mt-8 inline-flex rounded-full px-6 py-3 text-sm font-semibold text-white transition"
    >
      返回首页 · Back to Home
    </a>
  </section>
</BaseLayout>
