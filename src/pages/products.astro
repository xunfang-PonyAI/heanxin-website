---
import BaseLayout from "../layouts/BaseLayout.astro";
import IconFeatureCard from "../components/IconFeatureCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProductTaxonomyCard from "../components/ProductTaxonomyCard.astro";
import ProductShowcaseGrid from "../components/ProductShowcaseGrid.astro";
import T from "../components/T.astro";
import products from "../content/products.json";
import showcase from "../content/showcase.json";
import { url } from "../lib/i18n";
---

<BaseLayout
  title="产品分类"
  description="禾安鑫制造塑胶电子外壳、工业塑胶零部件、智能家居与小家电配件、汽车塑胶零部件、五金塑胶嵌件成型件、定制塑胶产品和展示盒。"
>
  <section class="container-page pt-12 pb-8">
    <SectionHeader title={products.header.title} subtitle={products.header.subtitle} as="h1" />
  </section>

  <section class="container-page pb-12">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        products.categories.map((category) => (
          <ProductTaxonomyCard
            no={category.no}
            title={category.title}
            desc={category.desc}
            examples={category.examples}
          />
        ))
      }
    </div>
  </section>

  <section class="section-tint border-line border-y py-14">
    <div class="container-page">
      <SectionHeader
        eyebrow={showcase.header.eyebrow}
        title={showcase.header.title}
        subtitle={showcase.header.subtitle}
      />
      <div class="mt-10">
        <ProductShowcaseGrid items={showcase.products} />
      </div>
    </div>
  </section>

  <section class="container-page py-14">
    <SectionHeader title={showcase.whyChooseUs.title} />
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        showcase.whyChooseUs.reasons.map((reason) => (
          <IconFeatureCard icon={reason.icon} title={reason.title} desc={reason.desc} />
        ))
      }
    </div>
  </section>

  <section class="section-tint border-line border-y py-14">
    <div class="container-page flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-2xl">
        <h2 class="font-display text-brand-700 text-3xl font-bold">
          <T text={products.cta.title} />
        </h2>
        <p class="text-muted mt-3 leading-relaxed">
          <T text={products.cta.desc} />
        </p>
      </div>
      <a
        href={url("/contact#quote")}
        class="bg-ember-500 hover:bg-ember-600 inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5"
      >
        <T text={products.cta.button} />
      </a>
    </div>
  </section>
</BaseLayout>
