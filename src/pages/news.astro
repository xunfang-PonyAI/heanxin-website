---
import BaseLayout from "../layouts/BaseLayout.astro";
import NewsSearch from "../components/NewsSearch.astro";
import SectionHeader from "../components/SectionHeader.astro";
import news from "../content/news.json";
---

<BaseLayout
  title="新闻资讯"
  description="禾安鑫新闻资讯提供塑胶注塑、材料选择、电子外壳选材、定制塑胶项目启动和模具开发流程等制造知识。"
>
  <section class="container-page pt-12 pb-8">
    <SectionHeader title={news.header.title} subtitle={news.header.subtitle} as="h1" />
  </section>

  <section class="container-page pb-14">
    <NewsSearch articles={news.articles} />
  </section>
</BaseLayout>
