---
import BaseLayout from "../layouts/BaseLayout.astro";
import CapabilityStrip from "../components/CapabilityStrip.astro";
import HomeHero from "../components/HomeHero.astro";
import HomeSolutionCard from "../components/HomeSolutionCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import T from "../components/T.astro";
import { url } from "../lib/i18n";
import home from "../content/home.json";
import media from "../content/media.json";

const assets = media.assetMap;
---

<BaseLayout
  title="塑胶注塑与模具定制制造商"
  description="禾安鑫专注塑胶注塑、模具开发、嵌件注塑与五金塑胶组合件，为电子、汽车、医疗等行业提供 OEM / ODM 一站式定制制造服务。"
>
  <HomeHero
    title={home.hero.title}
    subtitle={home.hero.subtitle}
    image={assets[home.hero.image]}
    primaryCta={{ label: home.hero.primaryCta, href: "/contact#quote", icon: "document" }}
    secondaryCta={{ label: home.hero.secondaryCta, href: "/contact", icon: "mail" }}
  />

  <section class="container-page py-10">
    <h2 class="font-display text-brand-800 text-center text-3xl font-bold">
      <T text={home.coreSolutions.title} />
    </h2>
    <div class="mt-7 grid gap-5 lg:grid-cols-2 xl:grid-cols-4">
      {
        home.coreSolutions.items.map((item) => (
          <HomeSolutionCard
            icon={item.icon}
            title={item.title}
            desc={item.desc}
            image={assets[item.image]}
            href={item.href}
          />
        ))
      }
    </div>
    <div class="mt-8">
      <CapabilityStrip items={home.capabilityStrip.items} />
    </div>
  </section>

  <section class="container-page py-16">
    <SectionHeader
      eyebrow={home.processPreview.eyebrow}
      title={home.processPreview.title}
      subtitle={home.processPreview.subtitle}
    />
    <div class="mt-10">
      <ProcessStepper steps={home.processPreview.steps} />
    </div>
  </section>

  <section class="bg-brand-700 py-14">
    <div class="container-page flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-ember-400">
          <span lang="en">Request a Quote</span><span lang="zh">项目询盘</span>
        </p>
        <h2 class="font-display mt-2 text-3xl font-bold text-white">
          <span lang="en">Send drawings, samples or project requirements.</span><span lang="zh"
            >发送图纸、样品或项目需求。</span
          >
        </h2>
        <p class="text-brand-100 mt-3 leading-relaxed">
          <span lang="en"
            >Share product type, material, quantity and file status so we can evaluate tooling and
            production feasibility.</span
          ><span lang="zh"
            >请提供产品类型、材料、数量和图纸文件情况，便于我们评估开模和生产可行性。</span
          >
        </p>
      </div>
      <a
        href={url("/contact#quote")}
        class="bg-ember-500 hover:bg-ember-600 inline-flex items-center justify-center rounded-full px-6 py-3 text-sm font-semibold text-white transition hover:-translate-y-0.5"
      >
        <span lang="en">Get a Quote</span><span lang="zh">获取报价</span>
      </a>
    </div>
  </section>
</BaseLayout>
