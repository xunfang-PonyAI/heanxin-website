---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import HighlightStat from "../components/HighlightStat.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import PhotoPlaceholder from "../components/PhotoPlaceholder.astro";
import mold from "../content/mold.json";
---

<BaseLayout
  title="模具开发与生产能力"
  description="禾安鑫拥有自有模具车间与最大 800 吨注塑机群，提供从模具设计、CNC 加工、试模到量产维护的完整模具开发与精密注塑生产能力。"
>
  <Hero eyebrow={mold.hero.eyebrow} title={mold.hero.title} subtitle={mold.hero.subtitle} compact />

  <section class="bg-brand-700 py-20">
    <div class="container-page">
      <SectionHeader title={mold.process.title} tone="dark" />
      <div class="mt-12">
        <ProcessStepper steps={mold.process.steps} />
      </div>
    </div>
  </section>

  <section class="container-page py-20">
    <div class="grid grid-cols-2 gap-4 lg:grid-cols-4">
      {mold.gallery.map((g) => <PhotoPlaceholder alt={g.alt} ratio="square" />)}
    </div>
  </section>

  <section class="from-brand-600 to-brand-800 bg-gradient-to-br py-20">
    <div class="container-page">
      <SectionHeader title={{ en: "Production Capability", zh: "生产能力亮点" }} tone="dark" />
      <div class="mt-12 grid gap-6 sm:grid-cols-3">
        {
          mold.capabilities.map((c) => (
            <HighlightStat icon={c.icon} title={c.title} desc={c.desc} />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
