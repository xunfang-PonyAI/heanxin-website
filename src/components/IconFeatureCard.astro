---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";

interface Props {
  icon?: string;
  no?: string;
  title: LocalizedText;
  desc?: LocalizedText;
}

const { icon, no, title, desc } = Astro.props;
---

<div
  class="group bg-surface hover:border-brand-200 border-line h-full rounded-[var(--radius-card)] border p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-card)]"
>
  <div class="flex items-start gap-4">
    {
      icon && (
        <div class="bg-brand-500 ring-brand-100 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-white ring-4 transition-transform duration-200 group-hover:scale-105">
          <Icon name={icon} class="h-6 w-6" />
        </div>
      )
    }
    <div class="min-w-0">
      <h3 class="font-display text-brand-700 text-lg font-semibold">
        {no && <span class="text-accent">{no}) </span>}
        {title.en}
      </h3>
      <p class="text-muted mt-0.5 text-sm font-medium">{title.zh}</p>
    </div>
  </div>
  {
    desc && (
      <p class="text-muted border-line mt-4 border-t pt-4 text-sm leading-relaxed">
        {desc.en}
        <span class="mt-1 block text-xs opacity-80">{desc.zh}</span>
      </p>
    )
  }
</div>
