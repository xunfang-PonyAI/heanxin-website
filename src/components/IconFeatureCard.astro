---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";

interface Props {
  icon?: string;
  no?: string;
  title: LocalizedText;
  desc?: LocalizedText;
}

const { icon, no, title, desc } = Astro.props;
---

<div
  class="group bg-surface hover:border-brand-200 border-line relative h-full overflow-hidden rounded-[var(--radius-card)] border p-6 transition-all duration-200 hover:-translate-y-1 hover:shadow-[var(--shadow-card)]"
>
  <span
    class="bg-ember-500 absolute inset-x-0 top-0 h-1 origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"
    aria-hidden="true"></span>
  <div class="flex items-start gap-4">
    {
      icon && (
        <div class="bg-brand-500 ring-brand-100 group-hover:bg-ember-500 group-hover:ring-ember-100 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full text-white ring-4 transition-all duration-200 group-hover:scale-105">
          <Icon name={icon} class="h-6 w-6" />
        </div>
      )
    }
    <div class="min-w-0">
      <h3 class="font-display text-brand-700 text-xl font-semibold">
        {no && <span class="text-ember-600">{no}) </span>}
        {title.en}
      </h3>
      <p class="text-muted mt-1 text-base font-medium">{title.zh}</p>
    </div>
  </div>
  {
    desc && (
      <p class="text-muted border-line mt-4 border-t pt-4 text-[15px] leading-relaxed">
        {desc.en}
        <span class="mt-1.5 block text-sm opacity-90">{desc.zh}</span>
      </p>
    )
  }
</div>
