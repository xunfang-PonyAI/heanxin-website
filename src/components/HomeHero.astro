---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Cta {
  label: LocalizedText;
  href: string;
  icon?: string;
}

interface Props {
  title: LocalizedText;
  subtitle: LocalizedText;
  image: ImageAsset;
  primaryCta: Cta;
  secondaryCta?: Cta;
}

const { title, subtitle, image, primaryCta, secondaryCta } = Astro.props;
---

<section class="home-hero border-line relative overflow-hidden border-b">
  <div class="home-hero__wash" aria-hidden="true"></div>
  <div class="container-page relative min-h-[620px] py-10 lg:min-h-[560px] lg:py-12">
    <div class="home-hero__media pointer-events-none absolute inset-0 z-10" aria-hidden="true">
      <div class="home-hero__product-field" aria-hidden="true"></div>
      <div class="home-hero__curve" aria-hidden="true"></div>
      <img
        src={url(image.src)}
        width={image.width}
        height={image.height}
        alt=""
        loading="eager"
        decoding="async"
        fetchpriority="high"
        sizes="(min-width: 1024px) 88vw, 110vw"
        class="home-hero__art absolute h-auto max-w-none"
      />
    </div>

    <div data-reveal class="home-hero__copy relative z-20 max-w-2xl">
      <h1
        class="font-display text-brand-800 max-w-3xl text-4xl leading-[1.05] font-bold sm:text-5xl xl:text-6xl"
      >
        <T text={title} />
      </h1>
      <p class="text-brand-500 mt-4 max-w-xl text-xl leading-snug font-semibold">
        <span lang="en">Factory-Direct. Mold Development. OEM & ODM.</span>
        <span lang="zh">工厂直供 · 模具开发 · OEM / ODM 定制</span>
      </p>
      <p class="text-muted mt-4 max-w-xl leading-relaxed">
        <T text={subtitle} />
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={url(primaryCta.href)}
          class="bg-brand-500 hover:bg-brand-600 inline-flex items-center justify-center gap-2 rounded-lg px-7 py-3.5 text-sm font-semibold text-white shadow-[var(--shadow-ember)] transition hover:-translate-y-0.5"
        >
          <Icon name={primaryCta.icon ?? "document"} class="h-5 w-5" />
          <T text={primaryCta.label} />
        </a>
        {
          secondaryCta && (
            <a
              href={url(secondaryCta.href)}
              class="border-brand-300 text-brand-600 hover:bg-brand-50 inline-flex items-center justify-center gap-2 rounded-lg border bg-white/70 px-7 py-3.5 text-sm font-semibold transition hover:-translate-y-0.5"
            >
              <Icon name={secondaryCta.icon ?? "mail"} class="h-5 w-5" />
              <T text={secondaryCta.label} />
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    background: linear-gradient(
      135deg,
      var(--color-brand-50) 0%,
      color-mix(in srgb, var(--color-brand-50) 62%, var(--color-canvas)) 30%,
      color-mix(in srgb, var(--color-canvas) 92%, var(--color-brand-50)) 58%,
      var(--color-canvas) 100%
    );
  }

  .home-hero__wash {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        58% 58% at 24% 18%,
        color-mix(in srgb, var(--color-brand-100) 80%, transparent),
        transparent 70%
      ),
      radial-gradient(
        42% 44% at 36% 88%,
        color-mix(in srgb, var(--color-ember-100) 36%, transparent),
        transparent 68%
      );
    pointer-events: none;
  }

  .home-hero__copy {
    padding-top: clamp(2.75rem, 7vw, 5rem);
  }

  .home-hero__media {
    isolation: isolate;
    overflow: visible;
  }

  .home-hero__product-field {
    position: absolute;
    z-index: 1;
    left: -50vw;
    right: -8rem;
    top: -4rem;
    bottom: -3rem;
    background:
      radial-gradient(
        ellipse 68% 78% at 76% 46%,
        var(--color-canvas) 0%,
        var(--color-canvas) 66%,
        color-mix(in srgb, var(--color-canvas) 88%, transparent) 80%,
        transparent 100%
      ),
      linear-gradient(
        90deg,
        transparent 0%,
        transparent 34%,
        color-mix(in srgb, var(--color-canvas) 24%, transparent) 46%,
        color-mix(in srgb, var(--color-canvas) 82%, transparent) 56%,
        var(--color-canvas) 64%,
        var(--color-canvas) 100%
      );
    pointer-events: none;
  }

  .home-hero__art {
    z-index: 2;
    right: -5.5rem;
    bottom: 1.4rem;
    width: min(82vw, 980px);
    filter: drop-shadow(
      0 1.35rem 1.55rem color-mix(in srgb, var(--color-brand-900) 13%, transparent)
    );
  }

  .home-hero__curve {
    position: absolute;
    z-index: 0;
    right: -11rem;
    bottom: -4.2rem;
    width: min(78vw, 940px);
    height: min(38vw, 440px);
    border-radius: 50% 0 0 50% / 58% 0 0 42%;
    background: radial-gradient(
      ellipse at 42% 52%,
      transparent 57%,
      color-mix(in srgb, var(--color-brand-200) 16%, transparent) 58%,
      transparent 63%
    );
    opacity: 0.28;
  }

  @media (max-width: 1023px) {
    .home-hero {
      background: linear-gradient(180deg, var(--color-canvas) 0%, var(--color-brand-50) 100%);
    }

    .home-hero .container-page {
      min-height: 760px;
    }

    .home-hero__copy {
      padding-top: 2.25rem;
    }

    .home-hero__product-field {
      left: -50vw;
      right: -9rem;
      top: 27.5rem;
      bottom: -1.5rem;
      background:
        radial-gradient(
          ellipse 84% 72% at 68% 50%,
          var(--color-canvas) 0%,
          var(--color-canvas) 66%,
          color-mix(in srgb, var(--color-canvas) 88%, transparent) 82%,
          transparent 100%
        ),
        linear-gradient(
          90deg,
          transparent 0%,
          color-mix(in srgb, var(--color-canvas) 24%, transparent) 26%,
          color-mix(in srgb, var(--color-canvas) 88%, transparent) 40%,
          var(--color-canvas) 56%,
          var(--color-canvas) 100%
        );
    }

    .home-hero__art {
      right: -8.25rem;
      bottom: -0.2rem;
      width: min(145vw, 565px);
    }

    .home-hero__curve {
      right: -13rem;
      bottom: -2rem;
      width: min(150vw, 620px);
      height: 18rem;
      border-radius: 50% 0 0 50%;
      opacity: 0.2;
    }
  }
</style>
