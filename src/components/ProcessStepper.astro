---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface Step {
  icon?: string;
  title: LocalizedText;
  desc?: LocalizedText;
}

interface Props {
  steps: Step[];
  tone?: "light" | "dark";
  variant?: "cards" | "timeline";
}

const { steps, tone = "light", variant = "cards" } = Astro.props;

const cardCls =
  tone === "dark"
    ? "border-white/15 bg-white/5 backdrop-blur-sm"
    : "border-line bg-white shadow-[var(--shadow-card)]";
const titleCls = tone === "dark" ? "text-white" : "text-brand-700";
const descCls = tone === "dark" ? "text-brand-100/85" : "text-muted";
const arrowCls = tone === "dark" ? "text-white/40" : "text-brand-300";
const numCls = tone === "dark" ? "bg-white text-brand-700" : "bg-brand-100 text-brand-700";

// Timeline variant — alternating vertical timeline. The dark ring color assumes
// the brand-700 section background used on the mold-capability page.
const lineCls = tone === "dark" ? "bg-white/20" : "bg-brand-200";
const nodeCls = tone === "dark" ? "bg-ember-500 ring-brand-700" : "bg-brand-500 ring-white";
const tlNumCls = tone === "dark" ? "text-ember-300" : "text-ember-600";
const tlTitleCls = tone === "dark" ? "text-white" : "text-brand-700";
const tlDescCls = tone === "dark" ? "text-brand-100/85" : "text-muted";
---

{
  variant === "timeline" ? (
    <ol class="relative mx-auto max-w-3xl">
      <span
        class={`pointer-events-none absolute top-2 bottom-2 left-6 w-0.5 -translate-x-1/2 sm:left-1/2 ${lineCls}`}
        aria-hidden="true"
      />
      {steps.map((step, i) => (
        <li class="relative" data-reveal>
          <span
            class={`absolute top-5 left-6 z-10 flex h-12 w-12 -translate-x-1/2 items-center justify-center rounded-full text-white ring-4 sm:left-1/2 ${nodeCls}`}
          >
            <Icon name={step.icon ?? "default"} class="h-6 w-6" />
          </span>
          <div
            class={`py-4 pl-16 sm:w-1/2 sm:py-6 ${i % 2 === 0 ? "sm:pr-14 sm:pl-0 sm:text-right" : "sm:ml-auto sm:pl-14"}`}
          >
            <p class={`font-display text-xs font-bold tracking-widest ${tlNumCls}`}>
              {String(i + 1).padStart(2, "0")}
            </p>
            <h3 class={`font-display mt-1 text-lg font-semibold ${tlTitleCls}`}>
              <T text={step.title} />
            </h3>
            {step.desc && (
              <p class={`mt-1.5 text-sm leading-relaxed ${tlDescCls}`}>
                <T text={step.desc} />
              </p>
            )}
          </div>
        </li>
      ))}
    </ol>
  ) : (
    <ol class="grid grid-cols-1 gap-x-4 gap-y-8 sm:grid-cols-2 lg:grid-cols-3">
      {steps.map((step, i) => (
        <li class="relative flex h-full" data-reveal>
          <div
            class={`card-interactive relative flex h-full w-full flex-col items-center rounded-[var(--radius-card)] border px-5 pt-8 pb-6 text-center ${cardCls}`}
          >
            <span
              class={`font-display absolute -top-3 right-4 flex h-7 w-7 items-center justify-center rounded-full text-xs font-bold ${numCls}`}
            >
              {String(i + 1).padStart(2, "0")}
            </span>
            <div class="bg-brand-500 ring-brand-100 mb-4 inline-flex h-14 w-14 items-center justify-center rounded-full text-white ring-4">
              <Icon name={step.icon ?? "default"} class="h-7 w-7" />
            </div>
            <h3 class={`font-display text-lg font-semibold ${titleCls}`}>
              <T text={step.title} />
            </h3>
            {step.desc && (
              <p class={`mt-2 text-sm leading-relaxed ${descCls}`}>
                <T text={step.desc} />
              </p>
            )}
          </div>
          {i < steps.length - 1 && (
            <span
              class:list={[
                "pointer-events-none absolute top-1/2 -right-3 z-10 hidden -translate-x-px -translate-y-1/2 sm:block",
                arrowCls,
                (i + 1) % 2 === 0 && "sm:hidden",
                (i + 1) % 3 === 0 ? "lg:hidden" : "lg:block",
              ]}
              aria-hidden="true"
            >
              <Icon name="arrowRight" class="h-5 w-5" />
            </span>
          )}
        </li>
      ))}
    </ol>
  )
}
