---
import type { LocalizedText } from "../lib/i18n";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface Props {
  icon?: string;
  title: LocalizedText;
  desc?: LocalizedText;
}

const { icon, title, desc } = Astro.props;
---

<div
  class="flex h-full flex-col items-center gap-4 rounded-[var(--radius-card)] border border-white/15 bg-white/5 p-7 text-center backdrop-blur-sm"
>
  {
    icon && (
      <div class="text-brand-600 inline-flex h-16 w-16 items-center justify-center rounded-full bg-white shadow-lg ring-4 ring-white/20">
        <Icon name={icon} class="h-8 w-8" />
      </div>
    )
  }
  <div>
    <h3 class="font-display text-xl font-semibold text-white"><T text={title} /></h3>
  </div>
  {
    desc && (
      <p class="text-brand-100/85 text-[15px] leading-relaxed">
        <T text={desc} />
      </p>
    )
  }
</div>
