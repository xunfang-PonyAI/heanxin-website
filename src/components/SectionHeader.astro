---
import type { LocalizedText } from "../lib/i18n";
import T from "./T.astro";

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  align?: "left" | "center";
  tone?: "light" | "dark";
}

const { eyebrow, title, subtitle, align = "center", tone = "light" } = Astro.props;

const alignCls = align === "center" ? "mx-auto text-center" : "text-left";
const titleColor = tone === "dark" ? "text-white" : "text-brand-700";
const subColor = tone === "dark" ? "text-brand-100" : "text-muted";
const eyebrowColor = tone === "dark" ? "text-ember-400" : "text-ember-700";
const barCenter = align === "center" ? "justify-center" : "";
---

<div class={`max-w-3xl ${alignCls}`}>
  {
    eyebrow && (
      <p class={`eyebrow ${eyebrowColor}`}>
        <T text={eyebrow} />
      </p>
    )
  }
  <h2 class={`font-display mt-3 text-4xl font-bold tracking-tight sm:text-5xl ${titleColor}`}>
    <span lang="en" class="uppercase">{title.en}</span><span lang="zh">{title.zh}</span>
  </h2>
  <div class={`accent-bar mt-5 ${barCenter}`} aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
  </div>
  {
    subtitle && (
      <p class={`mt-5 text-lg leading-relaxed ${subColor}`}>
        <T text={subtitle} />
      </p>
    )
  }
</div>
