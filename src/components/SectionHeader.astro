---
import type { LocalizedText } from "../lib/i18n";

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  align?: "left" | "center";
  tone?: "light" | "dark";
}

const { eyebrow, title, subtitle, align = "center", tone = "light" } = Astro.props;

const alignCls = align === "center" ? "mx-auto text-center" : "text-left";
const titleColor = tone === "dark" ? "text-white" : "text-brand-700";
const subColor = tone === "dark" ? "text-brand-100" : "text-muted";
const barCenter = align === "center" ? "justify-center" : "";
const barMain = tone === "dark" ? "bg-white" : "bg-brand-500";
const barTail = tone === "dark" ? "bg-brand-100/50" : "bg-brand-300/60";
---

<div class={`max-w-2xl ${alignCls}`}>
  {
    eyebrow && (
      <p class="eyebrow">
        {eyebrow.en} · {eyebrow.zh}
      </p>
    )
  }
  <h2
    class={`font-display mt-3 text-3xl font-bold tracking-tight uppercase sm:text-4xl ${titleColor}`}
  >
    {title.en}
  </h2>
  <p class={`mt-1 text-lg font-semibold ${subColor}`}>{title.zh}</p>
  <div class={`mt-4 flex items-center gap-1.5 ${barCenter}`} aria-hidden="true">
    <span class={`h-1 w-10 rounded-full ${barMain}`}></span>
    <span class={`h-1 w-16 rounded-full ${barTail}`}></span>
    <span class={`h-1.5 w-1.5 rounded-full ${barMain}`}></span>
  </div>
  {
    subtitle && (
      <p class={`mt-5 text-base leading-relaxed ${subColor}`}>
        {subtitle.en}
        <br />
        <span class="text-sm opacity-80">{subtitle.zh}</span>
      </p>
    )
  }
</div>
