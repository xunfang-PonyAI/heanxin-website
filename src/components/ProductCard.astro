---
import type { LocalizedText } from "../lib/i18n";
import PhotoPlaceholder from "./PhotoPlaceholder.astro";
import T from "./T.astro";

interface Props {
  title: LocalizedText;
  alt: LocalizedText;
}

const { title, alt } = Astro.props;
---

<div
  class="card-base group h-full overflow-hidden transition-transform duration-200 hover:-translate-y-1"
>
  <PhotoPlaceholder alt={alt} ratio="square" labelStyle="none" class="rounded-none border-0" />
  <div class="p-4">
    <h3 class="font-display text-brand-700 text-base font-semibold"><T text={title} /></h3>
  </div>
</div>
