---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";
import ResponsiveImage from "./ResponsiveImage.astro";
import T from "./T.astro";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Cta {
  label: LocalizedText;
  href: string;
}

interface Props {
  title: LocalizedText;
  subtitle: LocalizedText;
  eyebrow?: LocalizedText;
  image: ImageAsset;
  primaryCta: Cta;
  secondaryCta?: Cta;
}

const { title, subtitle, eyebrow, image, primaryCta, secondaryCta } = Astro.props;
---

<section class="section-tint border-line border-b">
  <div
    class="container-page grid gap-10 py-12 lg:grid-cols-[0.88fr_1.12fr] lg:items-center lg:py-16"
  >
    <div data-reveal>
      {
        eyebrow && (
          <p class="eyebrow text-ember-700">
            <T text={eyebrow} />
          </p>
        )
      }
      <h1
        class="font-display text-brand-800 mt-4 max-w-3xl text-4xl leading-tight font-bold sm:text-5xl"
      >
        <T text={title} />
      </h1>
      <p class="text-muted mt-5 max-w-2xl text-lg leading-relaxed">
        <T text={subtitle} />
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={url(primaryCta.href)}
          class="bg-ember-500 hover:bg-ember-600 shadow-ember-900/10 inline-flex items-center justify-center rounded-full px-7 py-3.5 text-sm font-semibold text-white shadow-sm transition hover:-translate-y-0.5"
        >
          <T text={primaryCta.label} />
        </a>
        {
          secondaryCta && (
            <a
              href={url(secondaryCta.href)}
              class="border-line text-brand-700 hover:bg-brand-50 inline-flex items-center justify-center rounded-full border bg-white px-7 py-3.5 text-sm font-semibold transition hover:-translate-y-0.5"
            >
              <T text={secondaryCta.label} />
            </a>
          )
        }
      </div>
    </div>
    <div data-reveal class="relative">
      <div class="border-line shadow-brand-900/10 bg-white p-2 shadow-2xl">
        <ResponsiveImage
          image={image}
          aspect="banner"
          fit="cover"
          priority
          sizes="(min-width: 1024px) 54vw, 100vw"
        />
      </div>
      <div
        class="border-line shadow-brand-900/10 absolute -bottom-5 left-6 hidden bg-white px-5 py-3 shadow-lg sm:block"
      >
        <p class="font-display text-brand-700 text-sm font-semibold">
          <span lang="en">OEM / ODM plastic injection manufacturing</span>
          <span lang="zh">OEM / ODM 塑胶注塑定制制造</span>
        </p>
      </div>
    </div>
  </div>
</section>
