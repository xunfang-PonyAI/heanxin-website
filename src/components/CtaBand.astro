---
import { site, url } from "../lib/i18n";
import Icon from "./Icon.astro";
import WorldMapDots from "./WorldMapDots.astro";

interface Props {
  title?: { en: string; zh: string };
}

const {
  title = {
    en: "Ready to Start Your Custom Project?",
    zh: "准备好开启您的定制项目了吗？",
  },
} = Astro.props;
const { contact } = site;
---

<section class="container-page py-16">
  <div
    class="from-brand-600 to-brand-800 relative overflow-hidden rounded-3xl bg-gradient-to-br px-8 py-12 sm:px-12 sm:py-14"
  >
    <WorldMapDots
      class="text-brand-300/15 pointer-events-none absolute -right-10 -bottom-12 hidden w-[420px] sm:block"
    />
    <div
      class="relative flex flex-col items-start justify-between gap-8 lg:flex-row lg:items-center"
    >
      <div>
        <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">{title.en}</h2>
        <p class="text-brand-100 mt-2 text-lg font-medium">{title.zh}</p>
      </div>
      <div class="flex flex-wrap gap-4">
        <a
          href={`https://wa.me/${contact.phoneRaw}`}
          target="_blank"
          rel="noopener"
          class="bg-ember-500 hover:bg-ember-600 inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-base font-semibold text-white shadow-[var(--shadow-ember)] transition"
        >
          WhatsApp 咨询
          <Icon name="arrowRight" class="h-5 w-5" />
        </a>
        <a
          href={url("/about")}
          class="inline-flex items-center rounded-full border border-white/50 px-7 py-3.5 text-base font-semibold text-white transition hover:border-white hover:bg-white/10"
        >
          联系我们 · Contact
        </a>
      </div>
    </div>
  </div>
</section>
