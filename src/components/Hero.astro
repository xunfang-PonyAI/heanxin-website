---
import type { LocalizedText } from "../lib/i18n";
import { url } from "../lib/i18n";
import WorldMapDots from "./WorldMapDots.astro";
import Icon from "./Icon.astro";
import T from "./T.astro";

interface Cta {
  label: LocalizedText;
  href: string;
}

interface Props {
  eyebrow?: LocalizedText;
  title: LocalizedText;
  subtitle?: LocalizedText;
  primaryCta?: Cta;
  secondaryCta?: Cta;
  compact?: boolean;
}

const { eyebrow, title, subtitle, primaryCta, secondaryCta, compact = false } = Astro.props;
---

<section
  class={`from-brand-700 via-brand-600 to-brand-800 relative overflow-hidden bg-gradient-to-br ${compact ? "py-20" : "py-24 sm:py-28 lg:py-32"}`}
>
  <!-- Decorative circuit grid -->
  <div
    class="pointer-events-none absolute inset-0 opacity-[0.10]"
    style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 48px 48px;"
    aria-hidden="true"
  >
  </div>
  <div
    class="bg-accent/30 pointer-events-none absolute -top-24 -right-24 h-96 w-96 rounded-full blur-3xl"
  >
  </div>

  <!-- Concentric arcs (top-right brochure motif) -->
  <svg
    class="pointer-events-none absolute -top-32 -right-24 h-[420px] w-[420px] text-white/10"
    viewBox="0 0 200 200"
    fill="none"
    stroke="currentColor"
    aria-hidden="true"
  >
    <circle cx="160" cy="40" r="120" stroke-width="0.8"></circle>
    <circle cx="160" cy="40" r="90" stroke-width="0.8"></circle>
    <circle cx="160" cy="40" r="60" stroke-width="0.8"></circle>
  </svg>

  <!-- World-map dots, lower-right -->
  <WorldMapDots
    class="text-brand-300/15 pointer-events-none absolute right-0 bottom-0 hidden w-[460px] lg:block"
  />

  <div class="container-page relative">
    <div class="grid items-center gap-12 lg:grid-cols-[1.5fr_1fr]">
      <div class="max-w-3xl">
        {
          eyebrow && (
            <p class="eyebrow text-ember-400">
              <T text={eyebrow} />
            </p>
          )
        }
        <h1
          class="font-display mt-4 text-4xl leading-[1.05] font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
        >
          <span lang="en" class="uppercase">{title.en}</span><span lang="zh">{title.zh}</span>
        </h1>
        <div class="mt-6 flex items-center gap-1.5" aria-hidden="true">
          <span class="bg-ember-500 h-1.5 w-12 rounded-full"></span>
          <span class="h-1.5 w-20 rounded-full bg-white/40"></span>
        </div>
        {
          subtitle && (
            <p class="text-brand-100/90 mt-6 max-w-2xl text-lg leading-relaxed sm:text-xl">
              <T text={subtitle} />
            </p>
          )
        }
        {
          (primaryCta || secondaryCta) && (
            <div class="mt-9 flex flex-wrap gap-4">
              {primaryCta && (
                <a
                  href={url(primaryCta.href)}
                  class="bg-ember-500 hover:bg-ember-600 inline-flex items-center gap-2 rounded-full px-7 py-3.5 text-base font-semibold text-white shadow-[var(--shadow-ember)] transition"
                >
                  <T text={primaryCta.label} />
                  <Icon name="arrowRight" class="h-5 w-5" />
                </a>
              )}
              {secondaryCta && (
                <a
                  href={url(secondaryCta.href)}
                  class="inline-flex items-center rounded-full border border-white/50 px-7 py-3.5 text-base font-semibold text-white transition hover:border-white hover:bg-white/10"
                >
                  <T text={secondaryCta.label} />
                </a>
              )}
            </div>
          )
        }
      </div>

      {
        !compact && (
          <div class="relative hidden lg:block">
            <div class="relative rounded-2xl border border-white/20 bg-white/5 p-6 backdrop-blur-sm">
              <span class="text-brand-100/70 font-display text-xs tracking-widest uppercase">
                Plastic · Mold · Hardware
              </span>
              <svg
                class="mt-3 w-full text-white/80"
                viewBox="0 0 320 200"
                fill="none"
                stroke="currentColor"
                stroke-width="1.4"
                aria-hidden="true"
              >
                <rect x="20" y="46" width="180" height="110" rx="8" stroke-opacity="0.5" />
                <path d="M40 150 L40 70 L120 70 L120 150" stroke-opacity="0.7" />
                <path d="M120 70 L160 40 L240 40 L200 70" stroke-opacity="0.7" />
                <path d="M200 70 L200 150 L120 150" stroke-opacity="0.7" />
                <circle cx="250" cy="120" r="34" stroke-opacity="0.6" />
                <circle cx="250" cy="120" r="14" stroke-opacity="0.6" />
                <path
                  d="M250 86 L250 70 M250 154 L250 170 M216 120 L200 120 M284 120 L300 120"
                  stroke-opacity="0.5"
                />
              </svg>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>
