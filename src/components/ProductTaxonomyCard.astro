---
import type { LocalizedText } from "../lib/i18n";
import ResponsiveImage from "./ResponsiveImage.astro";
import T from "./T.astro";

interface ImageAsset {
  src: string;
  width: number;
  height: number;
  alt: LocalizedText;
}

interface Props {
  no: string;
  title: LocalizedText;
  desc: LocalizedText;
  examples: LocalizedText[];
  image?: ImageAsset;
}

const { no, title, desc, examples, image } = Astro.props;
---

<article data-reveal class="card-base card-interactive group relative h-full overflow-hidden p-5">
  <span
    class="bg-ember-500 absolute inset-x-0 top-0 h-1 origin-left scale-x-0 transition-transform duration-300 group-hover:scale-x-100"
    aria-hidden="true"></span>
  {
    image && (
      <ResponsiveImage
        image={image}
        aspect="video"
        fit="contain"
        loading="eager"
        class="border-line mb-5 border bg-white p-3"
        sizes="(min-width: 1024px) 30vw, 100vw"
      />
    )
  }
  <p class="font-display text-ember-700 text-sm font-bold tracking-widest">{no}</p>
  <h2 class="font-display text-brand-700 mt-3 text-2xl font-semibold">
    <T text={title} />
  </h2>
  <p class="text-muted mt-4 text-[15px] leading-relaxed">
    <T text={desc} />
  </p>
  <div class="mt-5 flex flex-wrap gap-2">
    {
      examples.map((example) => (
        <span class="bg-brand-50 text-brand-700 rounded-full px-3 py-1 text-xs font-semibold">
          <T text={example} />
        </span>
      ))
    }
  </div>
</article>
