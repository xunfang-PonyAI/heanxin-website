---
interface Props {
  flip?: boolean;
  fill?: string;
  class?: string;
}

const { flip = false, fill = "#0d2b6b", class: className = "" } = Astro.props;
---

<svg
  class={`wave-divider ${className}`}
  viewBox="0 0 1440 120"
  preserveAspectRatio="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  style={flip ? "transform: rotate(180deg)" : undefined}
>
  <path fill={fill} d="M0,64 C240,112 480,16 720,40 C960,64 1200,112 1440,72 L1440,120 L0,120 Z"
  ></path>
</svg>
